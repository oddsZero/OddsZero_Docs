{
  "title": "OddsZero Documentation",
  "description": "Documentation for the OddsZero prediction market protocol",
  "root": ".",
  "language": "en",
  "structure": {
    "readme": "README.md",
    "summary": "SUMMARY.md"
  },
  "plugins": [
    "search-pro",
    "anchors",
    "copy-code-button",
    "back-to-top-button",
    "expandable-chapters",
    "splitter",
    "favicon",
    "hide-published-with"
  ],
  "pluginsConfig": {
    "favicon": {
      "shortcut": "assets/oddszero.png",
      "bookmark": "assets/oddszero.png"
    },
    "search-pro": {
      "cutWordPrefixLen": 3
    }
  }
}
